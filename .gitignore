# .gitignore - Complete

# ================================================================
# Airflow specific
# ================================================================
logs/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
airflow.db
airflow.cfg.backup*
unittests.cfg
airflow_login_attempts.db
standalone_admin_password.txt
webserver_config.py

# ================================================================
# Docker & Environment
# ================================================================
.env
.env.local
.env.*.local
.venv/
venv/
ENV/
env/
*.log

# ================================================================
# IDE & Editors
# ================================================================
.vscode/
.idea/
*.swp
*.swo
*.bak
.project
.pydevproject
.settings/
*.sublime-project
*.sublime-workspace

# ================================================================
# Database
# ================================================================
*.db
*.sqlite
*.sqlite3
postgres-db-volume/

# ================================================================
# Python
# ================================================================
*.egg-info/
dist/
build/
*.egg
.eggs/
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.mypy_cache/
.dmypy.json
dmypy.json

# ================================================================
# OS Files
# ================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ================================================================
# Backup Files
# ================================================================
backups/*.sql
*.backup
*.bak
*~

# ================================================================
# Streamlit
# ================================================================
.streamlit/secrets.toml
.streamlit/config.toml

# ================================================================
# Jupyter Notebooks
# ================================================================
.ipynb_checkpoints/
*.ipynb

# ================================================================
# Certificates & Keys
# ================================================================
*.pem
*.key
*.crt
*.p12

# ================================================================
# Temporary files
# ================================================================
tmp/
temp/
*.tmp
.cache/

# ================================================================
# Archives
# ================================================================
*.zip
*.tar
*.tar.gz
*.rar
*.7z

# ================================================================
# KEEP THESE FILES (explicitly NOT ignored)
# ================================================================
!.env.example
!.gitkeep
!README.md