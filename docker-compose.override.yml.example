# docker-compose.override.yml.example
# =================================================================
# DEVELOPMENT OVERRIDE CONFIGURATION
# Copy to docker-compose.override.yml for local development
# =================================================================

version: '3.8'

services:
  # Development settings for Airflow services
  airflow-webserver:
    environment:
      # Enable debug mode for development
      AIRFLOW__CORE__LOAD_EXAMPLES: 'true'
      AIRFLOW__WEBSERVER__RELOAD_ON_PLUGIN_CHANGE: 'true'
      AIRFLOW__WEBSERVER__AUTO_REFRESH_INTERVAL: '5'
      AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION: 'false'
      # Development logging
      AIRFLOW__LOGGING__LOGGING_LEVEL: 'DEBUG'
      AIRFLOW__CORE__COLORED_CONSOLE_LOG: 'true'
    # Mount source code for live reloading
    volumes:
      - ./:/opt/airflow/
    # Expose more ports for debugging
    ports:
      - "8080:8080"
      - "8793:8793"  # Log server
    # Reduce resource limits for development
    deploy:
      resources:
        limits:
          memory: 512M
        reservations:
          memory: 256M

  airflow-scheduler:
    environment:
      AIRFLOW__CORE__LOAD_EXAMPLES: 'true'
      AIRFLOW__LOGGING__LOGGING_LEVEL: 'DEBUG'
      AIRFLOW__SCHEDULER__DAG_DIR_LIST_INTERVAL: '60'
      AIRFLOW__SCHEDULER__MIN_FILE_PROCESS_INTERVAL: '10'
    volumes:
      - ./:/opt/airflow/
    deploy:
      resources:
        limits:
          memory: 512M
        reservations:
          memory: 256M

  airflow-worker:
    environment:
      AIRFLOW__CORE__LOAD_EXAMPLES: 'true'
      AIRFLOW__LOGGING__LOGGING_LEVEL: 'DEBUG'
      AIRFLOW__CELERY__WORKER_CONCURRENCY: '4'
    volumes:
      - ./:/opt/airflow/
    deploy:
      resources:
        limits:
          memory: 1G
        reservations:
          memory: 512M

  # Development database with exposed port
  postgres:
    ports:
      - "5432:5432"  # Expose for external access
    environment:
      # Less strict settings for development
      POSTGRES_INITDB_ARGS: "--encoding=UTF-8"
    volumes:
      # Use named volume instead of bind mount for development
      - postgres_dev_data:/var/lib/postgresql/data
    deploy:
      resources:
        limits:
          memory: 256M
        reservations:
          memory: 128M

  # Development Redis with exposed port
  redis:
    ports:
      - "6379:6379"  # Expose for external access
    deploy:
      resources:
        limits:
          memory: 64M

  # Add pgAdmin for database management
  pgadmin:
    image: dpage/pgadmin4:latest
    environment:
      PGADMIN_DEFAULT_EMAIL: admin@airflow.dev
      PGADMIN_DEFAULT_PASSWORD: admin
      PGADMIN_CONFIG_SERVER_MODE: 'False'
    ports:
      - "5050:80"
    volumes:
      - pgadmin_data:/var/lib/pgadmin
    depends_on:
      - postgres

  # Add Redis Commander for Redis management
  redis-commander:
    image: rediscommander/redis-commander:latest
    environment:
      REDIS_HOSTS: local:redis:6379
    ports:
      - "8081:8081"
    depends_on:
      - redis

  # Add Jupyter for data analysis and DAG development
  jupyter:
    image: jupyter/datascience-notebook:latest
    ports:
      - "8888:8888"
    environment:
      JUPYTER_ENABLE_LAB: 'yes'
      JUPYTER_TOKEN: 'airflow-dev'
    volumes:
      - ./notebooks:/home/jovyan/work
      - ./dags:/home/jovyan/dags
      - ./plugins:/home/jovyan/plugins
    command: start-notebook.sh --NotebookApp.token='airflow-dev'

  # Development file browser
  filebrowser:
    image: filebrowser/filebrowser:latest
    ports:
      - "8082:80"
    volumes:
      - ./:/srv
      - filebrowser_data:/database
    environment:
      FB_DATABASE: '/database/filebrowser.db'

volumes:
  postgres_dev_data:
  pgadmin_data:
  filebrowser_data:

# Development networks
networks:
  default:
    name: airflow_dev_network