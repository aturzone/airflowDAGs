# .env.example
# =================================================================
# AIRFLOW PRODUCTION ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to .env and update the values
# =================================================================

# ⚠️  REQUIRED: Update these values before running setup
# Database Configuration
POSTGRES_PASSWORD=CHANGE_THIS_PASSWORD_NOW_2024
POSTGRES_USER=airflow
POSTGRES_DB=airflow

# Admin User Configuration - UPDATE THESE
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=CHANGE_THIS_PASSWORD_NOW_2024
_AIRFLOW_WWW_USER_EMAIL=admin@yourcompany.com
_AIRFLOW_WWW_USER_FIRSTNAME=Admin
_AIRFLOW_WWW_USER_LASTNAME=User

# Security Keys - THESE WILL BE AUTO-GENERATED IF NOT SET
# Generate manually if needed:
# Fernet: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Secret: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
FERNET_KEY=auto_generated_if_empty
WEBSERVER_SECRET_KEY=auto_generated_if_empty

# System Configuration
AIRFLOW_UID=50000
AIRFLOW_PROJ_DIR=.

# Performance Tuning - Adjust based on your server resources
AIRFLOW__CORE__PARALLELISM=32
AIRFLOW__CORE__DAG_CONCURRENCY=16
AIRFLOW__CORE__MAX_ACTIVE_RUNS_PER_DAG=16
AIRFLOW__CORE__MAX_ACTIVE_TASKS_PER_DAG=16
AIRFLOW__CELERY__WORKER_CONCURRENCY=16

# Additional Python Requirements (Optional)
# Example: "pandas==1.5.3 requests==2.28.2 boto3==1.26.137"
_PIP_ADDITIONAL_REQUIREMENTS=

# Timezone Configuration
AIRFLOW__CORE__DEFAULT_TIMEZONE=UTC

# Logging Configuration
AIRFLOW__LOGGING__LOGGING_LEVEL=INFO
AIRFLOW__CORE__COLORED_CONSOLE_LOG=False

# Security Settings
AIRFLOW__WEBSERVER__EXPOSE_CONFIG=False
AIRFLOW__CORE__SECURE_MODE=True
AIRFLOW__API__ENABLE_EXPERIMENTAL_API=False

# Storage Configuration
AIRFLOW__CORE__STORE_SERIALIZED_DAGS=True
AIRFLOW__CORE__STORE_DAG_CODE=True

# =================================================================
# OPTIONAL CONFIGURATIONS - Uncomment and configure as needed
# =================================================================

# External Database Connection (if using external PostgreSQL)
# EXTERNAL_DB_HOST=your-production-db-host.com
# EXTERNAL_DB_PORT=5432
# EXTERNAL_DB_NAME=your_production_db
# EXTERNAL_DB_USER=your_production_user
# EXTERNAL_DB_PASSWORD=your_production_password

# Email/SMTP Configuration (for alerts and notifications)
# AIRFLOW__SMTP__SMTP_HOST=smtp.gmail.com
# AIRFLOW__SMTP__SMTP_STARTTLS=True
# AIRFLOW__SMTP__SMTP_SSL=False
# AIRFLOW__SMTP__SMTP_PORT=587
# AIRFLOW__SMTP__SMTP_USER=your-email@gmail.com
# AIRFLOW__SMTP__SMTP_PASSWORD=your-app-password
# AIRFLOW__SMTP__SMTP_MAIL_FROM=your-email@gmail.com

# Slack Integration (for notifications)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# AWS Configuration (if using AWS services)
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_DEFAULT_REGION=us-east-1

# Google Cloud Configuration (if using GCP)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# GOOGLE_CLOUD_PROJECT=your-gcp-project

# Azure Configuration (if using Azure)
# AZURE_CLIENT_ID=your_azure_client_id
# AZURE_CLIENT_SECRET=your_azure_client_secret
# AZURE_TENANT_ID=your_azure_tenant_id

# Monitoring and Metrics
# AIRFLOW__METRICS__STATSD_ON=True
# AIRFLOW__METRICS__STATSD_HOST=statsd-server
# AIRFLOW__METRICS__STATSD_PORT=8125
# AIRFLOW__METRICS__STATSD_PREFIX=airflow

# Advanced Scheduler Settings
# AIRFLOW__SCHEDULER__DAG_DIR_LIST_INTERVAL=300
# AIRFLOW__SCHEDULER__CATCHUP_BY_DEFAULT=False
# AIRFLOW__SCHEDULER__MAX_THREADS=2
# AIRFLOW__SCHEDULER__PARSING_PROCESSES=2

# Advanced Webserver Settings
# AIRFLOW__WEBSERVER__WORKERS=4
# AIRFLOW__WEBSERVER__WORKER_TIMEOUT=120
# AIRFLOW__WEBSERVER__WEB_SERVER_PORT=8080
# AIRFLOW__WEBSERVER__BASE_URL=http://localhost:8080

# =================================================================
# QUICK SETUP CHECKLIST:
# =================================================================
# 1. Copy this file to .env: cp .env.example .env
# 2. Update POSTGRES_PASSWORD with a strong password
# 3. Update _AIRFLOW_WWW_USER_PASSWORD with admin password
# 4. Update email address in _AIRFLOW_WWW_USER_EMAIL
# 5. Run setup: ./scripts/setup.sh
# 6. Access Airflow at http://localhost:8080
# =================================================================