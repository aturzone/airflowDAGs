# .env
# =================================================================
# AIRFLOW PRODUCTION ENVIRONMENT VARIABLES
# =================================================================

# Database Configuration
POSTGRES_PASSWORD=EKQH9jQX7gAfV7pLwVmsbLbF3XfY6n4S
POSTGRES_USER=airflow
POSTGRES_DB=airflow

# Security Keys (GENERATE THESE BEFORE PRODUCTION!)
# Generate Fernet Key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your_fernet_key_here_32_chars_base64_encoded

# Generate Secret Key: python -c "import secrets; print(secrets.token_urlsafe(32))"
WEBSERVER_SECRET_KEY=your_webserver_secret_key_here_32_chars

# Airflow User Configuration
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=QfUe9Bz3kZt2NsRb7hC8jXv9Lp6YwKdG
_AIRFLOW_WWW_USER_EMAIL=admin@company.com
_AIRFLOW_WWW_USER_FIRSTNAME=Admin
_AIRFLOW_WWW_USER_LASTNAME=User

# System Configuration
AIRFLOW_UID=50000
AIRFLOW_PROJ_DIR=.

# Additional Python Requirements (Optional)
# Example: "pandas==1.5.3 requests==2.28.2 boto3==1.26.137"
_PIP_ADDITIONAL_REQUIREMENTS=

# Performance Tuning
AIRFLOW__CORE__PARALLELISM=32
AIRFLOW__CORE__DAG_CONCURRENCY=16
AIRFLOW__CORE__MAX_ACTIVE_RUNS_PER_DAG=16
AIRFLOW__CORE__MAX_ACTIVE_TASKS_PER_DAG=16

# External Database Connection (if you want to connect to production DB)
# Uncomment and modify these if you have external PostgreSQL
# EXTERNAL_DB_HOST=your-production-db-host.com
# EXTERNAL_DB_PORT=5432
# EXTERNAL_DB_NAME=your_production_db
# EXTERNAL_DB_USER=your_production_user
# EXTERNAL_DB_PASSWORD=your_production_password

# Timezone Configuration
AIRFLOW__CORE__DEFAULT_TIMEZONE=UTC

# Email Configuration (Optional - for alerts)
# AIRFLOW__SMTP__SMTP_HOST=smtp.gmail.com
# AIRFLOW__SMTP__SMTP_STARTTLS=True
# AIRFLOW__SMTP__SMTP_SSL=False
# AIRFLOW__SMTP__SMTP_PORT=587
# AIRFLOW__SMTP__SMTP_USER=your-email@gmail.com
# AIRFLOW__SMTP__SMTP_PASSWORD=your-app-password
# AIRFLOW__SMTP__SMTP_MAIL_FROM=your-email@gmail.com

# Logging Configuration
AIRFLOW__LOGGING__LOGGING_LEVEL=INFO
AIRFLOW__CORE__COLORED_CONSOLE_LOG=False

# API Configuration  
AIRFLOW__API__ENABLE_EXPERIMENTAL_API=False

# Resource Limits
AIRFLOW__CELERY__WORKER_CONCURRENCY=16
AIRFLOW__CORE__STORE_SERIALIZED_DAGS=True
AIRFLOW__CORE__STORE_DAG_CODE=True

# Security
AIRFLOW__WEBSERVER__EXPOSE_CONFIG=False
AIRFLOW__CORE__SECURE_MODE=True